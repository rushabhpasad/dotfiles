# Source .profile in non-login interactive shells (login shells get it via .zprofile)
[ -z "$PROFILE_LOADED" ] && [ -r ~/.profile ] && source ~/.profile

# History
HISTSIZE=100000000
HISTFILESIZE=100000000
SAVEHIST=$HISTSIZE
setopt APPEND_HISTORY

# Activate homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"

# Activate fnm
# eval "$(fnm env --use-on-cd)"
eval "$(fnm env)"

# Activate pyenv
if command -v pyenv >/dev/null; then
    eval "$(pyenv init --path)"
    eval "$(pyenv init -)"
fi

# Activate sheldon
eval "$(sheldon source)"

# Activate Starship
eval "$(starship init zsh)"

# Aggregate all fpath additions before initializing completions
fpath=(/Users/rpasad/.docker/completions $fpath)

# Initialize completions once
autoload -Uz compinit && compinit
autoload bashcompinit && bashcompinit

# kubectl completion
[[ /opt/homebrew/bin/kubectl ]] && source <(kubectl completion zsh)

# AWS Autocomplete
complete -C '/opt/homebrew/bin/aws_completer' aws

# bun completions
[ -s "/Users/rpasad/.bun/_bun" ] && source "/Users/rpasad/.bun/_bun"

# SSH Config File Completion
h=()
if [[ -r ~/.ssh/config ]]; then
  h=($h ${${${(@M)${(f)"$(cat ~/.ssh/config)"}:#Host *}#Host }:#*[*?]*})
fi
if [[ $#h -gt 0 ]]; then
  zstyle ':completion:*:ssh:*' hosts $h
  zstyle ':completion:*:slogin:*' hosts $h
fi

# Custom aliases
alias reload="source ~/.zshrc"
if [ -r ~/.local-terminal-settings/.custom-alias ]; then
    source ~/.local-terminal-settings/.custom-alias
fi

# Custom functions
if [ -r ~/.local-terminal-settings/.zsh-functions ]; then
    source ~/.local-terminal-settings/.zsh-functions
fi

# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/opt/homebrew/Caskroom/miniconda/base/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh" ]; then
        . "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh"
    else
        export PATH="/opt/homebrew/Caskroom/miniconda/base/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<

