# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

LogLevel error  
StrictHostKeyChecking no  
UserKnownHostsFile /dev/null  
ServerAliveCountMax 18  
GSSAPIAuthentication yes  
GSSAPIDelegateCredentials yes  
# User rpasad

# Trust no one else  
Host *  
  IdentityFile ~/.ssh/id_rsa
  UseKeychain yes
  AddKeysToAgent yes
  ForwardAgent no  
  GSSAPIAuthentication no  
  GSSAPIDelegateCredentials no  
  HostkeyAlgorithms +ssh-rsa
  PubkeyAcceptedAlgorithms +ssh-rsa
  IdentitiesOnly yes
  ServerAliveInterval 30

Host stl
  HostName 100.66.55.82
  User stl
  IdentityFile ~/.ssh/id_rsa

Host stl-dev
  HostName 3.111.253.86
  User ec2-user
  IdentityFile ~/secrets/stl/dev/stl-dev-my-lightsail-instance-key-pair-01.pem
  
Host stl-prod
  HostName 13.203.84.155
  User ubuntu
  IdentityFile ~/secrets/stl/prod/stl-lightsail.pem
  
Host dymon-staging
  HostName 99.79.72.60
  User ubuntu
  IdentityFile ~/secrets/hnrtech/dymon/Dymon-stagings.pem