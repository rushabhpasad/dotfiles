########## ALIASES #################

# Git shortcuts
alias st="git st"
alias gdiff="git diff"
alias pull="git pull && git submodule sync --recursive && git submodule update --init --recursive"
alias push="git push"
alias stash="git stash"
alias co="git checkout"
alias gprune="rm .git/refs/remotes/origin/*"

# kubektl shortcuts
alias k='kubectl'
alias kdq='kubectl describe quota'
alias kd='kubectl get deployments'
alias kdd='kubectl describe'
alias kp='kubectl get pods'
alias kl='kubectl logs'
alias kuse='kubectl config use-context'
alias kset='kubectl config set-context --current --namespace'

# My Terminal shortcuts
alias rmds="find . -name .DS_Store -delete &"
#alias wget="curl -O"
alias ..="cd .."
alias l="ls --color -hal"
alias c="clear"
alias q="exit"
# alias grep="grep -n --color" 
alias hist="history 1"
alias h="history -10" # last 10 history commands
alias hg="hist | grep " # +command
alias r="reload"
alias p="ping google.com"
#alias killcamera="sudo killall VDCAssistant"
alias wget="curl -O"
alias ssho='ssh -o ForwardAgent=yes'

alias clauder='claude --resume'

alias docker-compose='docker compose'
alias dc='docker compose'

# scripts
alias chezbackup="~/scripts/chezmoi-auto-commit.sh"
alias bb="~/scripts/brew-maintenance.sh"
alias deepclean="~/scripts/quarterly-deep-clean.sh"


